# データベース（PostgreSQL）
DATABASE_URL="postgresql://user:password@localhost:5432/stanstore"
DIRECT_DATABASE_URL="postgresql://user:password@localhost:5432/stanstore"

# NextAuth（必須）
NEXTAUTH_SECRET="your-secret-here-generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Stripe（オプション - 未設定ならモック決済）
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# モック決済モード
USE_MOCK_PAYMENT="true"

# AI（オプション）
OPENAI_API_KEY=""
